# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# 通义千问 API（用于文本评审和离线评审）
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_TEXT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_MULTIMODAL_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_MODEL=qwen-vl-max

# Deepgram STT 配置（用于离线评审语音转文字）
DEEPGRAM_API_KEY=your-deepgram-api-key

# GetStream 配置（用于现场路演音视频）
GETSTREAM_API_KEY=your-getstream-api-key
GETSTREAM_API_SECRET=your-getstream-api-secret

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 文件上传限制（单位：字节）
MAX_PPT_SIZE=52428800
MAX_VIDEO_SIZE=524288000
